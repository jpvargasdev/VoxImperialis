# Required — XMPP credentials
XMPP_JID=vox@vox.imperialis
XMPP_PASSWORD=changeme
XMPP_SERVER=vox.imperialis:5222

# Set to "true" only if using a self-signed certificate
XMPP_TLS_SKIP_VERIFY=false

# Comma-separated list of JIDs allowed to send commands
ALLOWED_USERS=juan@vox.imperialis

# Comma-separated list of systemd services the bot may manage
ALLOWED_SERVICES=magos

# MachinusCronus API URL for watchface commands
MACHINUS_CRONUS_URL=http://machinuscronus:8081

# HTTP port for receiving notifications from other services
NOTIFY_PORT=8082
